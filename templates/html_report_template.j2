<!DOCTYPE html>
<html>
<head>
    <title>RHEL Patching Report</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; background: #f5f5f5; }
        .container { max-width: 1200px; margin: 0 auto; background: white; padding: 20px; border: 1px solid #ddd; }
        h1 { color: #333; border-bottom: 2px solid #0066cc; padding-bottom: 10px; }
        h2 { color: #555; margin-top: 30px; }
        .metadata { background: #f0f0f0; padding: 10px; margin: 10px 0; font-size: 14px; }
        .summary-table { width: 100%; border-collapse: collapse; margin: 20px 0; }
        .summary-table th, .summary-table td { border: 1px solid #ddd; padding: 10px; text-align: left; }
        .summary-table th { background: #0066cc; color: white; }
        .summary-table tr:nth-child(even) { background: #f9f9f9; }
        .status-success { color: green; font-weight: bold; }
        .status-failed { color: red; font-weight: bold; }
        .status-pending { color: orange; font-weight: bold; }
        .env-section { margin: 30px 0; border: 1px solid #ddd; padding: 15px; }
        .env-header { background: #333; color: white; padding: 10px; margin: -15px -15px 15px -15px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>RHEL Patching Report</h1>

        <div class="metadata">
            <strong>Generated:</strong> {{ timestamp }} |
            <strong>Execution ID:</strong> {{ execution_id }} |
            <strong>Total Duration:</strong> {{ total_duration }}
        </div>

        <h2>Summary</h2>
        <table class="summary-table">
            <tr>
                <th>Environment</th>
                <th>Total Servers</th>
                <th>Success</th>
                <th>Failed</th>
                <th>Pending</th>
                <th>Patches Applied</th>
                <th>Status</th>
            </tr>
            {% for env in environments %}
            <tr>
                <td><strong>{{ env.name | upper }}</strong></td>
                <td>{{ env.total }}</td>
                <td>{{ env.success }}</td>
                <td>{{ env.failed }}</td>
                <td>{{ env.pending }}</td>
                <td>{{ env.patches_applied }}</td>
                <td>
                    {% if env.failed > 0 %}
                        <span class="status-failed">FAILED</span>
                    {% elif env.pending > 0 %}
                        <span class="status-pending">IN PROGRESS</span>
                    {% else %}
                        <span class="status-success">COMPLETE</span>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
            <tr style="background: #e6f2ff; font-weight: bold;">
                <td>TOTAL</td>
                <td>{{ total_servers }}</td>
                <td>{{ total_success }}</td>
                <td>{{ total_failed }}</td>
                <td>{{ total_pending }}</td>
                <td>{{ total_patches }}</td>
                <td>{{ completion_percent }}% Complete</td>
            </tr>
        </table>

        {% for env in environments %}
        <div class="env-section">
            <div class="env-header">{{ env.name | upper }} Environment ({{ env.total }} servers)</div>
            <table class="summary-table">
                <tr>
                    <th>Server</th>
                    <th>IP Address</th>
                    <th>Current RHEL</th>
                    <th>Kernel</th>
                    <th>Patches Applied</th>
                    <th>Duration</th>
                    <th>Status</th>
                </tr>
                {% for server in env.servers %}
                <tr>
                    <td>{{ server.hostname }}</td>
                    <td>{{ server.ip }}</td>
                    <td>{{ server.rhel_version }}</td>
                    <td>{{ server.kernel }}</td>
                    <td>{{ server.patches }}</td>
                    <td>{{ server.duration }}</td>
                    <td>
                        {% if server.status == 'success' %}
                            <span class="status-success">SUCCESS</span>
                        {% elif server.status == 'failed' %}
                            <span class="status-failed">FAILED</span>
                        {% else %}
                            <span class="status-pending">{{ server.status | upper }}</span>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </table>
        </div>
        {% endfor %}

        <div class="metadata" style="margin-top: 30px;">
            <strong>Generated by:</strong> Ansible RHEL Patching Automation |
            <strong>Contact:</strong> {{ admin_email | default('admin@example.com') }}
        </div>
    </div>
</body>
</html>
